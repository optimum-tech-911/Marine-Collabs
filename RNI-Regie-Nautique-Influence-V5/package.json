{
  "name": "rni-regie-nautique-influence",
  "private": true,
  "version": "5.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generate-static-routes.mjs",
    "preview": "vite preview",
    "lint:types": "tsc -b --pretty false",
    "check": "npm run lint:types && npm run build",
    "verify:project": "node scripts/verify-project.mjs",
    "validate": "npm run check && npm run verify:project && npm run verify:content && npm run verify:static && npm run verify:routes",
    "verify:static": "node scripts/verify-static-routes.mjs",
    "verify:content": "node scripts/verify-content.mjs",
    "verify:routes": "node scripts/verify-route-responses.mjs",
    "doctor": "node scripts/doctor.mjs"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "motion": "12.42.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4"
  },
  "description": "Plateforme française premium pour une agence d’influence maritime.",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.2"
}
